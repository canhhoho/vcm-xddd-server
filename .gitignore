# ==================================
# CHỈ UPLOAD FOLDER server/ LÊN GITHUB
# Các file khác chỉ dùng local
# ==================================

# --- BỎ QUA TẤT CẢ MẶC ĐỊNH ---
*

# --- CHỈ CHO PHÉP CÁC FILE DEPLOY ---
!.gitignore

# Frontend build output
!dist/
!dist/**

# Frontend source code
!frontend/
!frontend/src/
!frontend/src/**
!frontend/public/
!frontend/public/**
!frontend/index.html
!frontend/package.json
!frontend/package-lock.json
!frontend/tsconfig.json
!frontend/tsconfig.app.json
!frontend/tsconfig.node.json
!frontend/vite.config.ts
!frontend/eslint.config.js
!frontend/.env.development
!frontend/.env.production

# Server source code (code chính)
!server/
!server/src/
!server/src/**

# Server dependencies
!server/package.json
!server/package-lock.json
!server/.env.example

# DB init scripts (cần cho lần đầu setup)
!server/scripts/
!server/scripts/init-db.sql
!server/scripts/seed-data.sql
!server/scripts/auto-migrate.js

# Upload folder structure
!server/uploads/
!server/uploads/.gitkeep

# --- LUÔN BỎ QUA ---
node_modules/
.env
.env.local
*.log
*.bak
